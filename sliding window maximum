class Solution {
public:
    vector<int> maxSlidingWindow(vector<int>& nums, int k) {
        int n = nums.size(), l = 0;
        vector<int> res;
        deque<int> d;
        
        for (int i = 0; i < n; i++) {
            // remove from the top while stale
            while (d.size() && d.front() < l) {
                d.pop_front();
            }
            
            // remove from back until you reach an element which is greater than current
            while (d.size() && nums[i] > nums[d.back()]) {
                d.pop_back();
            }

            // add current element in correct spot 
            d.push_back(i);

            // Add result and move window forward if window is size k
            if (i >= k-1) {
                res.push_back(nums[d.front()]);
                l++;
            }
        }

        return res; 
    }

};
